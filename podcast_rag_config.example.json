{
  "input_dir": "data",
  "file_glob": "**/*_speaker_transcript.json",
  "processed_dir": "processed",
  "state_path": "state/podcast_rag_state.json",
  "stop_file": "state/stop_after_current.txt",
  "control_file": "state/pipeline_control.json",
  "processed_data_dir": "processed_data",
  "debug_output_dir": "debug_output",
  "move_processed_files": false,
  "embedding_model": "BAAI/bge-large-en-v1.5",
  "lm_studio_base_url": "http://127.0.0.1:1234/v1",
  "lm_studio_api_key": "lm-studio",
  "lm_studio_model": "unsloth/qwen3.6-35b-a3b",
  "verify_model": true,
  "test_inference": true,
  "max_threads": 2,
  "max_parallel_model_requests": 2,
  "performance_report_interval_seconds": 30,
  "max_levels": 4,
  "max_clusters": 300,
  "min_docs_to_cluster": 12,
  "group_fallback_size": 6,
  "rollup_char_budget": 6000,
  "max_reduction_rounds": 8,
  "summary_target_chars": 1600,
  "leaf_chunk_size": 1800,
  "leaf_chunk_overlap": 250,
  "max_position_source_docs": 40,
  "position_extraction_batch_char_budget": 8000,
  "position_passage_max_chars": 900,
  "embedding_batch_size": 64,
  "llm_max_tokens": 4096
}
